{
	"name": "glow-card",
	"version": "0.0.1",
	"description": "Cursor-tracking glow border cards. Framework-agnostic Web Component. Zero dependencies, <1KB gzipped.",
	"type": "module",
	"license": "MIT",
	"author": "Franz Schlögel",
	"repository": {
		"type": "git",
		"url": "https://github.com/franzs/glow-card"
	},
	"keywords": [
		"glow",
		"card",
		"cursor",
		"hover",
		"border",
		"gradient",
		"web-component",
		"css",
		"ui",
		"animation",
		"effect"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./react": {
			"types": "./dist/react.d.ts",
			"import": "./dist/react.js",
			"require": "./dist/react.cjs"
		}
	},
	"main": "./dist/index.cjs",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": ["dist"],
	"scripts": {
		"build": "tsup",
		"dev": "tsup --watch",
		"check": "biome check .",
		"check:fix": "biome check --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"prepublishOnly": "npm run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/react": "^19.2.14",
		"jsdom": "^28.1.0",
		"tsup": "^8.3.0",
		"typescript": "^5.7.0",
		"vitest": "^3.0.0"
	},
	"peerDependencies": {
		"react": ">=19.0.0"
	},
	"peerDependenciesMeta": {
		"react": {
			"optional": true
		}
	}
}
